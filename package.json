{
  "name": "vexironathletics",
  "version": "1.0.0",
  "private": true,
  "description": "VexironAthletics full-stack e-commerce (Next.js + Express)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "build": "npm run build --prefix backend; npm run build --prefix frontend",
    "clean": "node -e \"const fs=require('fs');['frontend/.next','backend/dist'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true});console.log('Removed '+p);}catch(e){}})\"",
    "start": "node server.js",
    "postinstall": "npm install --prefix backend; npm install --prefix frontend",
    "knip": "knip",
    "typecheck": "npm run typecheck --prefix backend"
  },
  "dependencies": {
    "express": "^5.2.1",
    "next": "16.2.9",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "knip": "^6.20.0"
  }
}
